#!/bin/sh
# Wrapper for inittab's per-tty getty lines. Two gettys (hvc0 + ttyS0) are
# declared because the backend isn't known at squashfs-build time; this
# script picks the right one at boot via the kernel cmdline marker:
#
#   podroid.tty=hvc0   QEMU/TCG backend (virtio-console)
#   podroid.tty=hvc0   AVF/pKVM backend: AvfEngine boots with console=hvc0
#                      and emits podroid.tty=hvc0; crosvm's virtio-console is
#                      the AVF console with an input side. (The ttyS0 inittab
#                      line just parks via the wrong-tty sleep below.)
#
# If the marker is absent, default to hvc0 — that's QEMU's historical setup
# so legacy boots without the marker still get a login.
TTY="$1"
WANT=$(sed -n 's/.*podroid\.tty=\([a-zA-Z0-9]*\).*/\1/p' /proc/cmdline)
[ -z "$WANT" ] && WANT=hvc0

# Decision:
# - The primary tty pair (hvc0/ttyS0) is gated by the cmdline marker so only
#   the active backend's tty starts.
# - The multi-tab extras (hvc2/hvc3) start whenever their device node exists,
#   i.e. on QEMU's multi-virtconsole setup; on AVF the node is absent and we
#   park instead of letting busybox init throttle the respawn.
case "$TTY" in
    hvc0|ttyS0)
        [ "$TTY" = "$WANT" ] || exec sleep 2147483647
        ;;
    *)
        [ -c "/dev/$TTY" ] || exec sleep 2147483647
        ;;
esac

exec /sbin/getty -L -l /usr/local/bin/podroid-login 115200 "$TTY" xterm-256color
