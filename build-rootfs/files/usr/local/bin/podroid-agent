#!/usr/bin/env python3
"""
podroid-agent — Claude-Code-style local-LLM agent for Podroid.

Designed for small phone-CPU models (Qwen2.5-Coder-3B/7B Q4) running
inside the Podroid AI engine. Inline tool syntax (no JSON schema, no
MCP) keeps small models honest. UI mimics Claude Code: header with
model + cwd + context bar, live-streaming markdown panel, per-turn
token / tok-s / TTFB footer, tool-call & result panels, full-width
auto-redraw on terminal resize.

Tools (write each on its own line, anywhere in the assistant reply):
  !bash: <command>      run any shell command in cwd, pipes/redirects OK
  !ls: <path>           list a directory (raw path, no shell syntax)
  !read: <path>         cat a file (64 KiB cap)
  !write: <path>        write next ```fenced``` block to <path>
  !edit: <path>         search/replace inside a file (two ```fenced``` blocks: from, to)

No permission prompts. Tools execute immediately — the model controls
the agent loop. An 8-call-per-turn cap defuses runaway loops.
"""
from __future__ import annotations

import json
import os
import pathlib
import re
import signal
import subprocess
import sys
import threading
import time
from dataclasses import dataclass

import requests
from prompt_toolkit import PromptSession
from prompt_toolkit.formatted_text import HTML
from prompt_toolkit.history import FileHistory
from prompt_toolkit.key_binding import KeyBindings
from rich.box import Box, ROUNDED
from rich.console import Console, Group
from rich.live import Live
from rich.markdown import Markdown
from rich.padding import Padding
from rich.panel import Panel
from rich.progress_bar import ProgressBar
from rich.spinner import Spinner
from rich.table import Table
from rich.text import Text

# ── Charmtone-inspired palette ──────────────────────────────────────────────
# Mirrors Crush's "Pantera" dark theme: purple primary, pink accent, cool
# greens/yellows for success/info, salmon-red for errors. Named to match
# Crush's Go code so future updates are easy to backport.
class Style:
    CHARPLE  = "#8b65f6"   # primary purple
    DOLLY    = "#ff6bb5"   # accent pink
    PONY     = "#ff87d7"   # bright pink
    BLUSH    = "#ffafd7"   # soft pink (focus-tint)
    BOK      = "#5fd7d7"   # cyan info
    JULEP    = "#7be88a"   # success green
    BUTTER   = "#f5e082"   # warning yellow
    SRIRACHA = "#ff5757"   # error red
    SMOKE    = "#d0ccd0"   # default fg
    SQUID    = "#8c8c95"   # secondary fg
    OYSTER   = "#5c5c66"   # tertiary / dim
    PEPPER   = "#2a2a33"   # bg accent
    CHARCOAL = "#1c1c22"   # darkest bg

# Custom Box: vertical bar only on the left, no other borders. Mimics
# Crush's `lipgloss.Border{Left: "▌"}` focused-message style.
LEFT_BAR = Box(
    "    \n"  # top: empty
    "▌   \n"  # head row
    "▌   \n"  # head separator
    "▌   \n"  # row separator
    "▌   \n"  # row body
    "▌   \n"  # cross / mid foot
    "▌   \n"  # bottom separator
    "    \n", # bottom: empty
)

# ── Config ──────────────────────────────────────────────────────────────────
ENDPOINT_BASE = os.environ.get("PODROID_AI_HOST", "http://10.0.2.2:8089").rstrip("/")
CHAT_URL  = ENDPOINT_BASE + "/v1/chat/completions"
PROPS_URL = ENDPOINT_BASE + "/props"
HEALTH_URL = ENDPOINT_BASE + "/health"
MODEL = os.environ.get("OPENAI_MODEL_NAME", "podroid")
HISTDIR = pathlib.Path.home() / ".podroid-agent"
HISTDIR.mkdir(exist_ok=True)
MAX_TURNS = 24

console = Console()

# Enter sends the prompt; trailing `\` switches that one Enter to a
# newline (and the backslash is stripped so it doesn't ship to the
# model). Same convention as bash / Claude Code's continuation marker.
_input_bindings = KeyBindings()

@_input_bindings.add("enter")
def _enter(event):
    buf = event.current_buffer
    cursor_line = buf.document.current_line
    if cursor_line.endswith("\\"):
        # Strip the backslash, insert a newline, stay in the buffer.
        buf.delete_before_cursor(1)
        buf.insert_text("\n")
    else:
        buf.validate_and_handle()

session: PromptSession = PromptSession(
    history=FileHistory(str(HISTDIR / "history")),
    multiline=True,
    key_bindings=_input_bindings,
)

def prompt_indicator() -> HTML:
    """Crush-style `::: ` prompt — pink/magenta, distinctive enough that
    the user-typed-line is visually separable from the model output."""
    return HTML(f'\n<style fg="{Style.DOLLY}">::: </style>')

# cwd is tracked here, NOT in environment, because !bash: starts a new
# subprocess each call. !bash: cd … doesn't persist; the model is told
# to send !cd: instead (or use absolute paths). os.chdir() is called
# explicitly from the !cd: handler so !bash / !ls / !read also see it.
def cwd() -> str:
    return os.getcwd()

# ── Session statistics ──────────────────────────────────────────────────────
@dataclass
class Stats:
    session_in: int = 0
    session_out: int = 0
    turn_in: int = 0
    turn_out: int = 0
    turn_ttfb: float = 0.0
    turn_gen_time: float = 0.0
    ctx_used: int = 0
    ctx_max: int = 16384

    def reset_turn(self) -> None:
        self.turn_in = self.turn_out = 0
        self.turn_ttfb = self.turn_gen_time = 0.0

stats = Stats()

# ── System prompt ───────────────────────────────────────────────────────────
SYSTEM = f"""You are podroid-agent, a shell + file assistant in a Kali NetHunter VM.

OUTPUT FORMAT — read this carefully:
- To execute something, write a tool call on its own line starting with !
  THEN STOP. End your message right there. Do NOT write anything after the
  tool call — no preview of the output, no commentary. The system will run
  the tool and send you the real output in the next message.
- To answer in plain text, just write the text — no !prefix.
- NEVER output "tool result:" or "[OUTPUT]" — those are messages YOU receive,
  not messages you produce. You produce tool calls or plain text only.

GROUNDING RULE — ABSOLUTELY CRITICAL:
- Base every claim about commands/files/output on the LITERAL text in
  [OUTPUT] blocks. Do not infer, embellish, or make up details that
  aren't explicitly visible.
- If lsusb shows only host controllers, you say "only USB host
  controllers — no peripherals are currently attached". Do NOT say
  "a hub and a keyboard" unless those words appear in the output.
- When unsure, run another tool to verify instead of guessing.

Example of a correct turn:
  User: list the usb devices
  You:  !bash: lsusb
  (you receive [OUTPUT] with the lsusb text, then:)
  You:  Two USB host controllers are present; no peripheral devices
        are attached.

WRONG (do not do this):
  You: tool result: lsusb        ← wrong! Don't say "tool result"
  You: [OUTPUT] lsusb              ← wrong! Don't say "[OUTPUT]"
  You: bash: lsusb                 ← wrong! Missing the leading !
  You: You have 2 USB devices: a hub and a keyboard.   ← wrong!
        Those words aren't in the output — that's hallucination.

Current working directory: {{cwd}}
Relative paths in !ls / !read / !write / !edit resolve against this cwd.
!bash uses cwd as the subprocess working directory.

Available tools (each on its own line; pipes/redirects only inside !bash):

  !bash: <command>
      Run a shell command. Pipes, redirects, &&, globs OK.
      Each call is a fresh /bin/bash subprocess — `cd` doesn't persist.
      Use !cd: to change cwd, or pass absolute paths.

  !cd: <dir>
      Change the persistent cwd. Affects all later tools.

  !ls: <path>
      List a directory. Plain path only (no |, no globs).

  !read: <path>
      Cat a file. Capped at 64 KiB.

  !write: <path>
  ```
  <full file content, multi-line until the closing fence>
  ```

  !edit: <path>
  ```
  <exact text to find — must be unique in the file>
  ```
  ```
  <replacement text>
  ```

After a tool call you'll receive its output as a user message that
starts with [OUTPUT]. Use the output, then continue with another tool
call or a plain-text answer. When something fails, read the error
and adapt.

VM environment (constant — never guess):
- Hostname podroid · iface enp0s3 / 10.0.2.15/24 / gw 10.0.2.2 (Android host)
- Subnet 10.0.2.0/24. NEVER 192.168.x.x.
- USB-passthrough Wi-Fi: wlan0 / wlan1 when plugged in.
- Kali rolling — nmap, aircrack-ng, wireshark, lsusb already there.
- /mnt/android = 9p share to phone's /storage/emulated/0/Download.

Be concise. One tool call per reply when feasible. Plain-text replies
end the turn.
"""

def system_prompt() -> str:
    return SYSTEM.replace("{cwd}", cwd())

# ── llama-server introspection ─────────────────────────────────────────────
def probe_context_window() -> int:
    try:
        r = requests.get(PROPS_URL, timeout=2)
        if r.status_code != 200:
            return 16384
        data = r.json()
        for path in (
            ("default_generation_settings", "n_ctx"),
            ("n_ctx",),
            ("default_generation_settings", "params", "n_ctx"),
        ):
            cur: object = data
            for key in path:
                if not isinstance(cur, dict) or key not in cur:
                    cur = None
                    break
                cur = cur[key]
            if isinstance(cur, int) and cur > 0:
                return cur
    except Exception:
        pass
    return 16384

# ── Tool implementations ────────────────────────────────────────────────────
def resolve(p: str) -> str:
    """Resolve a path against the agent's cwd (so the model's relative
    paths Just Work even though each bash subprocess starts fresh)."""
    p = p.strip()
    return p if os.path.isabs(p) else os.path.join(cwd(), p)

def run_bash(cmd: str) -> str:
    try:
        proc = subprocess.run(
            cmd, shell=True, executable="/bin/bash",
            capture_output=True, text=True, timeout=120,
            cwd=cwd(),
        )
    except subprocess.TimeoutExpired:
        return "[timeout after 120s]"
    out = proc.stdout
    if proc.stderr:
        out += ("\n" if out else "") + proc.stderr
    return f"[exit={proc.returncode}]\n{out}".rstrip()

def run_cd(dest: str) -> str:
    p = resolve(dest or ".")
    try:
        os.chdir(p)
        return f"[cwd → {cwd()}]"
    except OSError as e:
        return f"[error: {e}]"

def run_ls(path: str) -> str:
    p = resolve(path or ".")
    try:
        items = sorted(os.listdir(p))
    except OSError as e:
        return f"[error: {e}]"
    return "\n".join(items) if items else "[empty]"

def run_read(path: str) -> str:
    try:
        with open(resolve(path), "r", encoding="utf-8", errors="replace") as f:
            return f.read(64 * 1024)
    except OSError as e:
        return f"[error: {e}]"

def run_write(path: str, content: str) -> str:
    try:
        p = pathlib.Path(resolve(path))
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_text(content)
        return f"[wrote {len(content)} bytes to {p}]"
    except OSError as e:
        return f"[error: {e}]"

def run_edit(path: str, find_text: str, replace_text: str) -> str:
    try:
        p = pathlib.Path(resolve(path))
        original = p.read_text()
    except OSError as e:
        return f"[error reading: {e}]"
    if find_text not in original:
        return "[error: 'find' text not present in file]"
    if original.count(find_text) > 1:
        return f"[error: 'find' text appears {original.count(find_text)} times; must be unique]"
    new = original.replace(find_text, replace_text, 1)
    try:
        p.write_text(new)
    except OSError as e:
        return f"[error writing: {e}]"
    return f"[edited {p} — {len(find_text)} → {len(replace_text)} bytes]"

# ── Tool-call parser ────────────────────────────────────────────────────────
TOOL_RE = re.compile(r"^!(bash|cd|ls|read|write|edit):\s*(.*)$", re.MULTILINE)
FENCE_RE = re.compile(r"```\n?(.*?)\n?```", re.DOTALL)

def is_complete_tool_call(text: str) -> bool:
    """True iff `text` already contains a syntactically-complete tool
    call — used to abort the stream early, before the model can
    fabricate its own pseudo [OUTPUT] block underneath.

    Single-line tools (bash / cd / ls / read) are complete once the
    args line ends in a newline. Block tools (write / edit) need 1 or
    2 fenced blocks respectively to close out.
    """
    m = TOOL_RE.search(text)
    if not m:
        return False
    tool = m.group(1)
    after = text[m.end():]
    if tool in ("bash", "cd", "ls", "read"):
        return "\n" in after
    if tool == "write":
        return after.count("```") >= 2
    if tool == "edit":
        return after.count("```") >= 4
    return False

def parse_first_tool(text: str) -> tuple[str, str, list[str]] | None:
    """Return (tool, args, fenced_blocks) for the first tool call in
    text, or None. fenced_blocks is a list of fenced-code-block contents
    that follow the tool call line (write→1 block, edit→2 blocks)."""
    m = TOOL_RE.search(text)
    if not m:
        return None
    tool, args = m.group(1), m.group(2).strip()
    after = text[m.end():]
    if tool in ("write", "edit"):
        blocks = []
        for fence in FENCE_RE.finditer(after):
            blocks.append(fence.group(1))
            if (tool == "write" and len(blocks) == 1) or \
               (tool == "edit" and len(blocks) == 2):
                break
        return tool, args, blocks
    return tool, args, []

def execute_tool(tool: str, args: str, blocks: list[str]) -> str:
    if tool == "bash":  return run_bash(args)
    if tool == "cd":    return run_cd(args)
    if tool == "ls":    return run_ls(args)
    if tool == "read":  return run_read(args)
    if tool == "write":
        if len(blocks) < 1:
            return "[error: !write needs a ```fenced``` block with the content]"
        return run_write(args, blocks[0])
    if tool == "edit":
        if len(blocks) < 2:
            return "[error: !edit needs TWO ```fenced``` blocks — first the search, then the replace]"
        return run_edit(args, blocks[0], blocks[1])
    return f"[unknown tool: {tool}]"

# ── Rich rendering helpers ──────────────────────────────────────────────────
def _short_cwd() -> str:
    """Shorten cwd: replace $HOME with ~, cap at 40 chars from the right."""
    s = cwd()
    home = str(pathlib.Path.home())
    if s == home:
        return "~"
    if s.startswith(home + os.sep):
        s = "~" + s[len(home):]
    if len(s) > 40:
        s = "…" + s[-39:]
    return s

def status_line() -> Text:
    """Status bar shown at the BOTTOM of every live render — Crush
    positions context info there. Left half: model + cwd; right half:
    session token counters + context-window %.  Auto-fills the width."""
    cw = console.size.width
    ctx_pct = (stats.ctx_used / stats.ctx_max * 100) if stats.ctx_max else 0
    left = Text()
    left.append("  ●  ", style=f"bold {Style.DOLLY}")
    left.append(MODEL, style=f"bold {Style.SMOKE}")
    left.append("  ", style="")
    left.append(_short_cwd(), style=Style.SQUID)
    right = Text()
    right.append(f"{stats.session_in}↑", style=Style.BOK)
    right.append("/", style=Style.OYSTER)
    right.append(f"{stats.session_out}↓", style=Style.JULEP)
    right.append("   ", style="")
    right.append(f"ctx {stats.ctx_used}/{stats.ctx_max} ", style=Style.SQUID)
    bar_color = (Style.JULEP if ctx_pct < 50
                 else Style.BUTTER if ctx_pct < 80
                 else Style.SRIRACHA)
    right.append(f"({ctx_pct:.0f}%)", style=bar_color)
    pad = max(1, cw - left.cell_len - right.cell_len)
    return Text.assemble(left, Text(" " * pad), right)

def assistant_render(content: str, streaming: bool) -> Group:
    """Crush-style assistant block: left bar, bullet header, indented
    markdown content. No surrounding box — just the vertical accent."""
    if content:
        body = Markdown(content, code_theme="dracula")
    else:
        body = Spinner("dots", text=Text("thinking…", style=Style.SQUID))
    # Header bullet
    header = Text.assemble(
        ("  ", ""),
        ("●", f"bold {Style.PONY}"),
        ("  ", ""),
        ("assistant", f"bold {Style.SMOKE}"),
        ("  ·  ", Style.OYSTER),
        (f"{stats.turn_out} tok", Style.JULEP) if not streaming else
        ("streaming", Style.SQUID),
    )
    return Group(
        header,
        Padding(body, (0, 0, 0, 5)),  # 5-char indent = past the "●  "
    )

def tool_call_render(tool: str, args: str, blocks: list[str]) -> Group:
    """Compact Crush-style tool call: `→  !tool: args` header in cyan,
    plus a single fenced block preview for !write / !edit."""
    head = Text.assemble(
        ("  ", ""),
        ("→", f"bold {Style.BOK}"),
        ("  ", ""),
        (f"!{tool}: ", f"bold {Style.BOK}"),
        (args, Style.SMOKE),
    )
    pieces = [head]
    if blocks:
        for blk in blocks[:2]:
            preview = blk[:160] + ("…" if len(blk) > 160 else "")
            pieces.append(Padding(
                Text(preview, style=Style.SQUID),
                (0, 0, 0, 5),
            ))
    return Group(*pieces)

def tool_result_render(result: str, dt: float) -> Group:
    """Compact tool result: `←  exit=N (Xs)` header colour-coded by
    exit code, with indented output below."""
    # Extract exit code if present
    exit_code = None
    body = result
    if result.startswith("[exit="):
        end = result.find("]")
        if end > 0:
            try:
                exit_code = int(result[6:end])
                body = result[end+1:].lstrip("\n")
            except ValueError:
                pass

    if exit_code is None:
        glyph = "←"; glyph_style = f"bold {Style.SQUID}"
        status = ""
    elif exit_code == 0:
        glyph = "✓"; glyph_style = f"bold {Style.JULEP}"
        status = "ok"
    else:
        glyph = "✗"; glyph_style = f"bold {Style.SRIRACHA}"
        status = f"exit={exit_code}"

    head = Text.assemble(
        ("  ", ""),
        (glyph, glyph_style),
        ("  ", ""),
        ("result", f"bold {Style.SMOKE}"),
        ("  ·  ", Style.OYSTER),
        (status, Style.SQUID) if status else ("", ""),
        ("  " if status else "", ""),
        (f"{dt:.2f}s", Style.SQUID),
    )
    pieces = [head]
    if body.strip():
        display = body if len(body) < 3000 else body[:3000] + "\n…[truncated]"
        pieces.append(Padding(
            Text(display, style=Style.SMOKE),
            (0, 0, 0, 5),
        ))
    return Group(*pieces)

def turn_footer() -> Text:
    """Per-turn metrics line shown after each assistant block. Mirrors
    Claude Code's compact stats format."""
    if stats.turn_in == 0 and stats.turn_out == 0:
        return Text("")
    rate = stats.turn_out / stats.turn_gen_time if stats.turn_gen_time > 0 else 0
    f = Text()
    f.append("  ", "")
    f.append(f"{stats.turn_in}↑", style=Style.BOK)
    f.append(" ", "")
    f.append(f"{stats.turn_out}↓", style=Style.JULEP)
    f.append("  ·  ", style=Style.OYSTER)
    f.append(f"ttfb {stats.turn_ttfb:.1f}s", style=Style.BUTTER)
    f.append("  ·  ", style=Style.OYSTER)
    f.append(f"{rate:.1f} tok/s", style=Style.PONY)
    f.append("  ·  ", style=Style.OYSTER)
    f.append(f"{stats.turn_gen_time:.1f}s total", style=Style.SQUID)
    return f

# ── Initialization warmup ──────────────────────────────────────────────────
def warmup_engine(system_msg: dict) -> bool:
    """Pre-eval BOTH the model weights AND the system prompt before the
    REPL accepts input. Sends a max_tokens=1 chat with the real system
    message + a 1-char user message; with cache_prompt=true llama-server
    keeps the resulting KV cache, so the user's first real turn only has
    to evaluate their own message — typical 5-10 s instead of 60+ s on
    phone CPU. Shows a live timer; returns True on success."""
    result: dict = {"done": False, "ok": False, "err": None,
                    "tokens_in": 0, "tokens_out": 0}

    def do_ping() -> None:
        try:
            r = requests.post(CHAT_URL, json={
                "model": MODEL,
                "stream": False,
                "messages": [system_msg, {"role": "user", "content": "."}],
                "max_tokens": 1,
                "temperature": 0,
                # llama.cpp / llama-server custom extension — keep the
                # evaluated prefix in the slot's KV cache so the next
                # request with the same system prompt skips re-eval.
                "cache_prompt": True,
            }, timeout=600)
            result["ok"] = r.status_code == 200
            if r.status_code == 200:
                u = r.json().get("usage") or {}
                result["tokens_in"] = u.get("prompt_tokens", 0)
                result["tokens_out"] = u.get("completion_tokens", 0)
            else:
                result["err"] = f"HTTP {r.status_code}: {r.text[:200]}"
        except requests.exceptions.RequestException as e:
            result["err"] = str(e)
        finally:
            result["done"] = True

    t0 = time.monotonic()
    t = threading.Thread(target=do_ping, daemon=True)
    t.start()

    def panel(elapsed: float) -> Panel:
        spin = Spinner("dots", text=Text.assemble(
            ("Initializing AI engine — loading model + pre-evaluating system prompt", f"bold {Style.SMOKE}"),
            ("\n\n", ""),
            ("One-time cost per session. After this completes, your first real prompt\n", Style.SQUID),
            ("only has to evaluate your own message — usually 5–10 s instead of 60+.\n\n", Style.SQUID),
            (f"Endpoint: ", Style.OYSTER), (ENDPOINT_BASE, Style.SMOKE), ("\n", ""),
            (f"Model:    ", Style.OYSTER), (MODEL, Style.SMOKE), ("\n", ""),
            (f"Elapsed:  ", Style.OYSTER), (f"{elapsed:.1f}s", f"bold {Style.BUTTER}"),
        ))
        return Panel(
            spin,
            title=Text.assemble(
                ("●  ", f"bold {Style.PONY}"),
                ("warming up", f"bold {Style.DOLLY}"),
            ),
            border_style=Style.CHARPLE, box=ROUNDED, padding=(1, 2),
        )

    with Live(panel(0.0), refresh_per_second=4, transient=True) as live:
        while not result["done"]:
            live.update(panel(time.monotonic() - t0))
            time.sleep(0.25)
        live.update(panel(time.monotonic() - t0))

    if result["ok"]:
        elapsed = time.monotonic() - t0
        stats.ctx_used = result["tokens_in"] + result["tokens_out"]
        console.print(Padding(
            Text.assemble(
                ("  ", ""),
                ("✓", f"bold {Style.JULEP}"),
                ("  Engine ready  ", f"bold {Style.SMOKE}"),
                ("·  ", Style.OYSTER),
                (f"loaded in {elapsed:.1f}s", Style.SQUID),
            ),
            (1, 0),
        ))
        return True
    console.print(Panel(
        Text.assemble(
            ("✗ Engine warmup failed.\n", f"bold {Style.SRIRACHA}"),
            (result["err"] or "(unknown)", Style.SRIRACHA),
            ("\n\nOn the phone:  Settings → AI Engine → Enable engine → wait for "
             "state Running → re-run podroid-agent.\n", Style.BUTTER),
        ),
        title=Text("✗ initialization error", style=f"bold {Style.SRIRACHA}"),
        border_style=Style.SRIRACHA, box=ROUNDED,
    ))
    return False

# ── SIGWINCH handler ───────────────────────────────────────────────────────
def install_sigwinch_handler() -> None:
    """Force Live renders + the next prompt redraw on terminal resize. Rich
    queries console.size per render so most repaints handle themselves; we
    only need to nudge prompt_toolkit if it's currently sitting on the
    prompt waiting for input."""
    def handler(signum, frame):
        try:
            session.app.invalidate()
        except Exception:
            pass
    try:
        signal.signal(signal.SIGWINCH, handler)
    except (AttributeError, ValueError):
        pass  # not on Linux, or already inside an event-loop installer

# ── LLM streaming with live markdown render ────────────────────────────────
def stream_completion(messages: list[dict]) -> str:
    body = {
        "model": MODEL,
        "stream": True,
        "stream_options": {"include_usage": True},
        "messages": messages,
        "temperature": 0.3,
        "max_tokens": 2048,
        # cache_prompt=true: llama-server's slot keeps the KV of the
        # longest matching prefix of `messages`. With our stable
        # system-prompt + warmup pre-eval, the first user turn skips
        # the system-prompt eval (~600 tokens) entirely.
        "cache_prompt": True,
        # Hard stops — keep the model from generating the words we use
        # to label tool results (it loves to mimic them and fabricate
        # output). Server cuts generation the moment it would emit
        # these substrings.
        "stop": ["[OUTPUT]", "\ntool result:", "\n\ntool result:"],
    }
    stats.reset_turn()
    t0 = time.monotonic()
    first_token_at: float | None = None
    chunks: list[str] = []
    stream_error: str | None = None

    try:
        r = requests.post(CHAT_URL, json=body, stream=True, timeout=300)
    except requests.exceptions.RequestException as e:
        console.print(Panel(
            f"[red]Engine unreachable: {e}[/red]\n\n"
            "On the phone: Settings → AI Engine → Restart, wait for Running, retry.",
            title="[red]connection error[/red]", border_style="red",
        ))
        return ""
    if r.status_code != 200:
        console.print(Panel(
            f"HTTP {r.status_code}\n{r.text[:400]}",
            title="[red]server error[/red]", border_style="red",
        ))
        return ""

    def render() -> Group:
        return Group(
            assistant_render("".join(chunks), streaming=True),
            Text(""),
            status_line(),
        )

    usage_payload: dict | None = None
    with Live(render(), console=console, refresh_per_second=8,
              transient=False, vertical_overflow="visible") as live:
        try:
            for line in r.iter_lines(decode_unicode=True):
                if not line or not line.startswith("data:"):
                    continue
                data = line[5:].strip()
                if data == "[DONE]":
                    break
                try:
                    obj = json.loads(data)
                except json.JSONDecodeError:
                    continue
                if "usage" in obj and obj["usage"]:
                    usage_payload = obj["usage"]
                choices = obj.get("choices") or []
                if not choices:
                    continue
                delta = choices[0].get("delta", {}).get("content", "")
                if delta:
                    if first_token_at is None:
                        first_token_at = time.monotonic()
                        stats.turn_ttfb = first_token_at - t0
                    chunks.append(delta)
                    live.update(render())
                    # Early-stop: as soon as the model has emitted a
                    # syntactically-complete tool call, cancel the
                    # stream — anything it writes after is fabrication
                    # ("preview of the output") which wastes tokens and
                    # confuses the next turn. Server-side generation
                    # continues briefly, but our parser sees only the
                    # tool call.
                    if is_complete_tool_call("".join(chunks)):
                        try:
                            r.close()
                        except Exception:
                            pass
                        break
        except (requests.exceptions.ChunkedEncodingError,
                requests.exceptions.ConnectionError,
                requests.exceptions.ReadTimeout) as e:
            stream_error = f"stream interrupted: {e.__class__.__name__}: {e}"

        stats.turn_gen_time = time.monotonic() - t0
        if usage_payload:
            stats.turn_in  = int(usage_payload.get("prompt_tokens", 0))
            stats.turn_out = int(usage_payload.get("completion_tokens", 0))
            stats.session_in  += stats.turn_in
            stats.session_out += stats.turn_out
            stats.ctx_used = int(usage_payload.get("total_tokens", stats.ctx_used))
        live.update(render())

    console.print(turn_footer())
    if stream_error:
        engine_state = "unknown"
        try:
            h = requests.get(HEALTH_URL, timeout=2)
            engine_state = ("ok" if h.status_code == 200
                            else f"{h.status_code} {h.text[:80]}")
        except Exception as e:
            engine_state = f"unreachable ({e.__class__.__name__})"
        console.print(Panel(
            f"[red]{stream_error}[/red]\n"
            f"engine /health: {engine_state}\n\n"
            "[yellow]Phone → Notification → Restart the AI engine, wait for "
            "state Running, then retry the same prompt.[/yellow]",
            title="[red]engine error[/red]", border_style="red",
        ))
    return "".join(chunks)

# ── REPL ────────────────────────────────────────────────────────────────────
def banner() -> None:
    """Crush-style launch banner — wordmark + endpoint info + key hints,
    rounded magenta border."""
    console.print(Panel.fit(
        Text.assemble(
            ("  ", ""),
            ("●", f"bold {Style.PONY}"),
            ("  ", ""),
            ("podroid-agent", f"bold {Style.DOLLY}"),
            ("\n", ""),
            ("  ", ""),
            ("local-LLM agent for Podroid — Crush-style UX\n", Style.SQUID),
            ("\n", ""),
            (f"  Endpoint   ", Style.OYSTER), (ENDPOINT_BASE, Style.SMOKE), ("\n", ""),
            (f"  Model      ", Style.OYSTER), (MODEL, Style.SMOKE), ("\n", ""),
            (f"  Context    ", Style.OYSTER), (f"{stats.ctx_max} tokens\n", Style.SMOKE),
            (f"  Working in ", Style.OYSTER), (cwd(), Style.SMOKE), ("\n\n", ""),
            ("  ", ""),
            ("Commands  ", f"bold {Style.BLUSH}"),
            ("/reset  /save NAME  /load NAME  /stats  /cwd  /exit  ·  Ctrl+D quit\n",
             Style.SQUID),
            ("  ", ""),
            ("Multi-line ", f"bold {Style.BLUSH}"),
            ("end a line with \\ to continue;  Enter sends.", Style.SQUID),
        ),
        border_style=Style.CHARPLE,
        box=ROUNDED,
        padding=(0, 1),
    ))

def show_stats() -> None:
    t = Table(title="Session statistics", show_header=False, border_style="dim")
    t.add_row("Endpoint",       ENDPOINT_BASE)
    t.add_row("Model",          MODEL)
    t.add_row("CWD",            cwd())
    t.add_row("Context window", f"{stats.ctx_max} tokens")
    t.add_row("Context used",   f"{stats.ctx_used} tokens "
                                f"({100*stats.ctx_used/max(stats.ctx_max,1):.1f}%)")
    t.add_row("Session prompt", f"{stats.session_in} tokens")
    t.add_row("Session output", f"{stats.session_out} tokens")
    console.print(t)

def main() -> None:
    stats.ctx_max = probe_context_window()
    install_sigwinch_handler()
    banner()

    # Build the system message ONCE here and feed it to the warmup so
    # llama-server's slot KV cache holds the evaluated system prompt
    # by the time the user's first turn arrives. Each turn will replace
    # messages[0] with the freshly-computed system_prompt() in case cwd
    # changed — but for the very first user turn, the prefix matches and
    # the eval is reused.
    initial_system = {"role": "system", "content": system_prompt()}
    if not warmup_engine(initial_system):
        return

    messages: list[dict] = [initial_system]

    while True:
        try:
            user = session.prompt(prompt_indicator()).strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\n[dim]bye[/dim]")
            return

        if not user:
            continue
        if user in ("/exit", "/quit"):
            return
        if user == "/reset":
            # Rebuild the system prompt so the latest cwd is baked in.
            messages = [{"role": "system", "content": system_prompt()}]
            stats.ctx_used = 0
            console.print("[dim](history cleared, cwd refreshed)[/dim]")
            continue
        if user == "/cwd":
            console.print(f"[cyan]cwd:[/cyan] {cwd()}")
            continue
        if user == "/stats":
            show_stats()
            continue
        if user.startswith("/save "):
            name = user[6:].strip() or "default"
            (HISTDIR / f"{name}.json").write_text(json.dumps(messages, indent=2))
            console.print(f"[dim](saved as {name})[/dim]")
            continue
        if user.startswith("/load "):
            name = user[6:].strip() or "default"
            path = HISTDIR / f"{name}.json"
            if not path.exists():
                console.print(f"[red](no saved session: {name})[/red]")
                continue
            messages = json.loads(path.read_text())
            console.print(f"[dim](loaded {name}, {len(messages)} turns)[/dim]")
            continue

        # Each turn refreshes the system message so the model sees the
        # current cwd if the user did /cd or the previous turn used !cd:.
        messages[0] = {"role": "system", "content": system_prompt()}
        messages.append({"role": "user", "content": user})

        for _ in range(8):
            reply = stream_completion(messages)
            if not reply:
                break
            messages.append({"role": "assistant", "content": reply})

            parsed = parse_first_tool(reply)
            if not parsed:
                break
            tool, args, blocks = parsed
            console.print(tool_call_render(tool, args, blocks))
            t_tool = time.monotonic()
            result = execute_tool(tool, args, blocks)
            tool_dt = time.monotonic() - t_tool
            console.print(tool_result_render(result, tool_dt))
            messages.append({"role": "user",
                             "content": f"[OUTPUT]\n{result}"})

        if len(messages) > 2 * MAX_TURNS + 1:
            messages = [messages[0]] + messages[-2 * MAX_TURNS:]


if __name__ == "__main__":
    main()
