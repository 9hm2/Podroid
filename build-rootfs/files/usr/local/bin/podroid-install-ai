#!/bin/bash
# Podroid - Rootless Podman for Android
# Copyright (C) 2024-2026 Podroid contributors
#
# Set up local-LLM CLI tools (Aider + shell-gpt) inside the Podroid VM,
# pointed at the Android-side llama-server over SLIRP loopback. Idempotent
# — re-running this script is a no-op when everything is already there.
#
# Works two ways:
#   1. Pre-installed in /usr/local/bin/podroid-install-ai by the rootfs
#      build, so a freshly-booted VM just needs `sudo podroid-install-ai`.
#   2. Pulled into an already-running VM via:
#        curl -fsSL <repo-raw-url>/podroid-install-ai | sudo bash
#      (the script tolerates being piped through bash — no $0 magic)

set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# Config
# ─────────────────────────────────────────────────────────────────────────────
LLAMA_HOST="${PODROID_AI_HOST:-http://10.0.2.2:8089}"
ENV_FILE="/etc/profile.d/podroid-ai.sh"
AIDER_CONF_SKEL="/etc/skel/.aider.conf.yml"

# pipx defaults install to per-user ~/.local/bin which doesn't help other
# users (and the VM has root + the user accounts kismet/etc. spawn). Pin
# pipx to a system-wide layout: venvs under /opt/pipx/venvs, bin symlinks
# in /usr/local/bin, so `aider` resolves for every login session.
export PIPX_HOME=/opt/pipx
export PIPX_BIN_DIR=/usr/local/bin
export PIPX_MAN_DIR=/usr/local/share/man

# ─────────────────────────────────────────────────────────────────────────────
# Logging helpers
# ─────────────────────────────────────────────────────────────────────────────
BLUE='\033[1;34m'; GREEN='\033[1;32m'; YELLOW='\033[1;33m'; RED='\033[1;31m'; NC='\033[0m'
log()   { printf "${BLUE}==>${NC} %s\n" "$*"; }
ok()    { printf "${GREEN}  ✓${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}  ⚠${NC} %s\n" "$*"; }
fail()  { printf "${RED}  ✗${NC} %s\n" "$*" >&2; }

usage() {
    cat <<EOF
podroid-install-ai — set up local-LLM CLI tools in the VM

Usage: podroid-install-ai [tool ...]

Tools:
  aider     AI pair programming, file edit, git-aware  (~50 MB)
  sgpt      shell-gpt: prompt → shell command          (~10 MB)
  crush     Claude-Code-like agentic TUI (bash + edit) (~15 MB)
  gptme     Full agent: shell + python + edit + browser (~80 MB)
  all       Install everything                         (default)
  --help    Show this message

Env:
  PODROID_AI_HOST   Override the llama-server URL
                    (default: http://10.0.2.2:8089 — Android via SLIRP)

Model recommendation for agentic use (crush, gptme, aider tool-loops):
  Qwen2.5-Coder-7B Q4_0  — code-tuned 7B, follows structured tool-use
                            reliably. Select in Podroid Settings → AI
                            Engine → Model. 3B-class models hallucinate
                            tool calls and loop.

After install, open a new shell or 'source /etc/profile.d/podroid-ai.sh',
then:
  aider                          # AI pair programming
  sgpt "list /var/log tail-50"   # one-shot prompt
  crush                          # interactive TUI agent (Claude-Code-like)
  gptme "scan the local subnet"  # full agent w/ shell+python tools
  podroid-ai "..."               # tiny curl wrapper (already shipped)
EOF
}

# ─────────────────────────────────────────────────────────────────────────────
# Pre-flight
# ─────────────────────────────────────────────────────────────────────────────
require_root() {
    if [ "$(id -u)" -ne 0 ]; then
        fail "Must run as root (uses apt + writes to /opt, /etc, /usr/local)."
        echo "Try: sudo podroid-install-ai $*" >&2
        exit 1
    fi
}

check_engine() {
    log "Checking AI engine reachability at $LLAMA_HOST"
    if curl -fsS --connect-timeout 3 "$LLAMA_HOST/health" >/dev/null 2>&1; then
        ok "llama-server responding"
        return 0
    fi
    warn "llama-server not responding at $LLAMA_HOST/health"
    cat <<EOM
       On the phone:
         Open Podroid → Settings → AI Engine
           1. Download a model (Qwen2.5 3B recommended for Z Fold 5)
           2. Toggle "Enable AI engine" ON
       Then run this script again.

       Continuing anyway — installs still work; the tools will just fail
       to connect until the engine is up.
EOM
}

# ─────────────────────────────────────────────────────────────────────────────
# apt deps — pipx + python3-pip + curl. Kali ships python3 by default,
# pipx may be missing on older debootstraps.
# ─────────────────────────────────────────────────────────────────────────────
ensure_apt_deps() {
    log "Installing apt prerequisites (pipx, python3-pip, git, curl, jq)"
    local need=()
    for p in pipx python3-pip python3-venv git curl jq; do
        dpkg -s "$p" >/dev/null 2>&1 || need+=("$p")
    done
    if [ ${#need[@]} -gt 0 ]; then
        DEBIAN_FRONTEND=noninteractive apt-get update -qq
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends "${need[@]}"
    fi
    ok "apt deps in place"
}

# ─────────────────────────────────────────────────────────────────────────────
# Env file — sourced by every login shell. Both OPENAI_API_BASE and
# OPENAI_BASE_URL are exported because litellm/openai-python check
# different names depending on version. AIDER_* keys lock the model so
# `aider` works with no flags.
# ─────────────────────────────────────────────────────────────────────────────
write_env_file() {
    log "Writing $ENV_FILE"
    cat > "$ENV_FILE" <<EOF
# podroid-ai env — written by podroid-install-ai
# Routes any OpenAI-compatible CLI to the Android-side llama-server.
# Override PODROID_AI_HOST and re-run podroid-install-ai to change.

export OPENAI_API_BASE="$LLAMA_HOST/v1"
export OPENAI_BASE_URL="$LLAMA_HOST/v1"
export OPENAI_API_KEY="sk-podroid-local"
export OPENAI_MODEL_NAME="podroid"

# Aider expects litellm-style "<provider>/<model>" naming. We've registered
# the model alias "podroid" on the llama-server side, so this maps to
# whichever model is currently active in the phone's AI Engine settings.
export AIDER_MODEL="openai/podroid"
export AIDER_WEAK_MODEL="openai/podroid"

# pipx system layout — keep aider et al. visible to every user.
export PIPX_HOME=/opt/pipx
export PIPX_BIN_DIR=/usr/local/bin

# Silence noisy library warnings; turn this up if debugging.
export LITELLM_LOG=ERROR
EOF
    chmod 644 "$ENV_FILE"
    ok "$ENV_FILE installed (effective in new shells)"
    # Source for the rest of this script too.
    set +u
    # shellcheck disable=SC1090
    . "$ENV_FILE"
    set -u
}

# ─────────────────────────────────────────────────────────────────────────────
# Aider config skeleton — dropped in /etc/skel and copied to existing
# /root + /home/*. Removes the "which model?" prompt on first run and
# disables auto-commit (dangerous inside a pentest sandbox).
# ─────────────────────────────────────────────────────────────────────────────
write_aider_conf() {
    log "Writing default Aider config to $AIDER_CONF_SKEL"
    mkdir -p "$(dirname "$AIDER_CONF_SKEL")"
    cat > "$AIDER_CONF_SKEL" <<EOF
# ~/.aider.conf.yml — generated by podroid-install-ai
model: openai/podroid
weak-model: openai/podroid
openai-api-base: $LLAMA_HOST/v1
openai-api-key: sk-podroid-local

# Local model isn't trained on every git-flow nuance; explicit > auto.
auto-commits: false

# Don't nag about model capabilities — we know it's small.
show-model-warnings: false

# Saves a lot of stdout noise during tool-use loops.
stream: true
EOF
    # Copy into existing homedirs (idempotent — overwrite is fine, the
    # file is fully managed by this script).
    for h in /root /home/*; do
        [ -d "$h" ] || continue
        local owner
        owner=$(stat -c '%U:%G' "$h" 2>/dev/null) || continue
        install -m 644 -o "${owner%:*}" -g "${owner#*:}" \
            "$AIDER_CONF_SKEL" "$h/.aider.conf.yml"
    done
    ok "Aider config in /etc/skel + existing home dirs"
}

# ─────────────────────────────────────────────────────────────────────────────
# Tool installs
# ─────────────────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# Tool installs — Python tools go via uv (Astral) instead of bare pipx.
#
# Why uv: aider-chat (and most modern ML-adjacent Python tools) pulls
# numpy / pandas / scipy through transitive deps. On Python 3.13 (Kali
# rolling 2026+) those packages have no pre-built wheels for some pinned
# versions and pip falls back to compiling numpy 1.24.3 from source —
# which doesn't build on Python 3.13 at all, and even when it does needs
# BLAS/LAPACK headers we don't ship. uv's resolver picks newer wheel-
# available versions and uses --prefer-binary by default, sidestepping
# the whole build trap. pipx alone hits "Fatal error from pip: numpy".
# ─────────────────────────────────────────────────────────────────────────────

ensure_uv() {
    if command -v uv >/dev/null 2>&1; then
        return
    fi
    log "Bootstrapping uv (Astral Python tool installer)"
    # uv ships pre-built static binaries on PyPI. pipx grabs it cleanly.
    pipx install uv
    # uv's symlink lands in PIPX_BIN_DIR (/usr/local/bin) — make sure
    # PATH reflects that for the rest of this script even if our shell
    # was started before the pipx install ran.
    export PATH="$PIPX_BIN_DIR:$PATH"
    command -v uv >/dev/null 2>&1 || { fail "uv install failed"; exit 1; }
    ok "uv installed: $(uv --version 2>/dev/null)"
}

# uv tool install defaults to per-user dirs; pin to system layout so
# every login session resolves the binaries from /usr/local/bin.
export UV_TOOL_BIN_DIR=/usr/local/bin
export UV_TOOL_DIR=/opt/uv-tools

install_aider() {
    if command -v aider >/dev/null 2>&1; then
        ok "aider already installed: $(aider --version 2>/dev/null | head -1)"
        return
    fi
    ensure_uv
    # Clean up any half-installed mess from earlier pipx attempts so a
    # retry is truly idempotent — leftover venvs would otherwise shadow
    # uv's install.
    rm -rf "$PIPX_HOME/venvs/aider-chat" 2>/dev/null
    rm -rf /root/.local/share/pipx/venvs/aider-chat 2>/dev/null
    rm -f /usr/local/bin/aider 2>/dev/null
    # aider-chat pins numpy<2 (transitive through litellm + friends),
    # which forces numpy 1.26.x. That release line has NO pre-built
    # wheel for Python 3.13 (only 3.10-3.12) — uv would otherwise
    # fall back to compiling numpy from source, which needs gcc/clang
    # the rootfs doesn't have and Kali's apt currently can't supply
    # (gcc-16 transitive deps 404 mid-sync). --python 3.12 makes uv
    # download a standalone pre-built Python 3.12 and use *that* for
    # the install: numpy 1.26 wheel is available there, zero compilers
    # involved.
    log "Installing Aider via uv with Python 3.12 (pre-built wheels, ~50 MB)"
    uv tool install --python 3.12 aider-chat
    command -v aider >/dev/null 2>&1 && ok "aider installed: $(aider --version 2>/dev/null | head -1)"
}

install_sgpt() {
    if command -v sgpt >/dev/null 2>&1; then
        ok "sgpt already installed"
        return
    fi
    ensure_uv
    rm -rf "$PIPX_HOME/venvs/shell-gpt" 2>/dev/null
    rm -rf /root/.local/share/pipx/venvs/shell-gpt 2>/dev/null
    rm -f /usr/local/bin/sgpt 2>/dev/null
    # shell-gpt has no numpy dep so the host Python is fine, but
    # pinning the same 3.12 keeps uv's Python cache shared with aider —
    # a single ~30 MB download serves both tools.
    log "Installing shell-gpt via uv with Python 3.12 (~10 MB)"
    uv tool install --python 3.12 shell-gpt

    # Pre-seed a podroid-shell role: bakes the VM's network setup and
    # available toolchain into the system prompt so even the smaller
    # models stop guessing 192.168.x.x or treating interface names as
    # hostnames. Drops into every existing homedir + skel.
    for h in /etc/skel /root /home/*; do
        [ -d "$h" ] || continue
        local rolesdir="$h/.config/shell_gpt/roles"
        local owner=root:root
        [ "$h" != /etc/skel ] && owner=$(stat -c '%U:%G' "$h" 2>/dev/null) || true
        install -d -o "${owner%:*}" -g "${owner#*:}" "$rolesdir"
        cat > "$rolesdir/podroid-shell.json" <<EOF
{
  "name": "podroid-shell",
  "role": "You are a shell command assistant running inside a Kali NetHunter VM on Podroid. Output ONE shell command line, nothing else, no explanation, no markdown fences.\n\nVM environment (constant, do not guess these):\n- Hostname: podroid\n- Primary interface: enp0s3 with IP 10.0.2.15/24, MAC 52:54:00:12:34:56\n- Default gateway: 10.0.2.2 (the Android host, reachable as 'host' alias too)\n- Subnet: 10.0.2.0/24. DO NOT use 192.168.x.x — the actual range is 10.0.2.0/24.\n- USB-passthrough Wi-Fi adapters appear as wlan0/wlan1 only when plugged in.\n- /mnt/android is a 9p-share to the Android /storage/emulated/0/Download dir.\n- Kali rolling, full apt access. Prefer Kali's pre-installed pentest tools; apt install <pkg> for anything missing.\n- The Android-side AI engine is reachable at http://10.0.2.2:8089 (used by podroid-ai, sgpt, aider).\n\nWhen the user asks for an IP-based action, derive the IP from the live interface (ip route, ip a) rather than assuming. When asked to scan 'the network', use 10.0.2.0/24 unless explicitly told otherwise. Use full paths and quoted args."
}
EOF
        chown -R "$owner" "$rolesdir" 2>/dev/null || true
    done
    # shell-gpt's first run writes ~/.config/shell_gpt/.sgptrc — pre-seed
    # it so the user doesn't get prompted for an OpenAI key on a wholly
    # local install. Different per-home; touch root + existing humans.
    for h in /root /home/*; do
        [ -d "$h" ] || continue
        local cfg="$h/.config/shell_gpt/.sgptrc"
        [ -f "$cfg" ] && continue
        local owner
        owner=$(stat -c '%U:%G' "$h" 2>/dev/null) || continue
        install -d -o "${owner%:*}" -g "${owner#*:}" "$(dirname "$cfg")"
        cat > "$cfg" <<EOF
API_BASE_URL=$LLAMA_HOST/v1
OPENAI_API_KEY=sk-podroid-local
DEFAULT_MODEL=podroid
CHAT_CACHE_PATH=$h/.cache/shell_gpt/chat_cache
CACHE_PATH=$h/.cache/shell_gpt/cache
REQUEST_TIMEOUT=120
CHAT_CACHE_LENGTH=100
CACHE_LENGTH=100
DEFAULT_COLOR=magenta
ROLE_STORAGE_PATH=$h/.config/shell_gpt/roles
PRETTIFY_MARKDOWN=true
DEFAULT_EXECUTE_SHELL_CMD=false
DISABLE_STREAMING=false
CODE_THEME=dracula
EOF
        chown "$owner" "$cfg"
    done
    ok "shell-gpt + podroid-shell role + .sgptrc installed (use: sgpt --role podroid-shell --repl <name>)"
}

# ─────────────────────────────────────────────────────────────────────────────
# Crush — Claude-Code-like agentic TUI. Pre-built Go binary from upstream
# release, ~15 MB. Chat REPL + bash tool + file edit + memory; works on any
# OpenAI-compatible endpoint via $OPENAI_BASE_URL or its own config file.
# ─────────────────────────────────────────────────────────────────────────────
install_crush() {
    if command -v crush >/dev/null 2>&1; then
        ok "crush binary already installed: $(crush --version 2>/dev/null | head -1)"
    else
        log "Fetching Crush latest release for linux-arm64"
        # Resolve the latest tag and arm64 tarball URL from GitHub's releases
        # API. Tarball naming is `crush_<ver>_Linux_arm64.tar.gz`.
        local url
        url=$(curl -fsSL https://api.github.com/repos/charmbracelet/crush/releases/latest \
                | grep -oE '"browser_download_url": "[^"]*[Ll]inux_arm64\.tar\.gz"' \
                | head -1 | cut -d'"' -f4)
        test -n "$url" || { fail "couldn't resolve Crush arm64 release URL"; return 1; }
        curl -fsSL -o /tmp/crush.tar.gz "$url"
        tar xzf /tmp/crush.tar.gz -C /tmp
        install -m 755 /tmp/crush*/crush /usr/local/bin/crush
        rm -rf /tmp/crush*
    fi

    # ALWAYS rewrite the config — re-running the installer should
    # repair a broken / outdated JSON, not silently skip it because
    # `crush` happens to be present in $PATH. Earlier versions of this
    # script returned early here and left stale 8K configs in place.
    # filename is crush.json, NOT config.json). Schema docs at
    # https://charm.land/crush.json. Drop the same content into every
    # home dir so all users start pre-routed at the local server.
    for h in /etc/skel /root /home/*; do
        [ -d "$h" ] || continue
        local cfgdir="$h/.config/crush"
        local owner=root:root
        [ "$h" != /etc/skel ] && owner=$(stat -c '%U:%G' "$h" 2>/dev/null) || true
        install -d -o "${owner%:*}" -g "${owner#*:}" "$cfgdir"
        cat > "$cfgdir/crush.json" <<EOF
{
  "\$schema": "https://charm.land/crush.json",
  "providers": {
    "podroid": {
      "type": "openai-compat",
      "base_url": "$LLAMA_HOST/v1",
      "api_key": "sk-podroid-local",
      "models": [
        {
          "id": "podroid",
          "name": "Podroid Local LLM",
          "context_window": 16384,
          "default_max_tokens": 2048
        }
      ]
    }
  },
  "options": {
    "disabled_tools": [
      "sourcegraph", "fetch", "webfetch", "web_search",
      "agent", "diagnostics", "notebook", "thinking",
      "todo", "multiedit", "glob", "mcp"
    ]
  }
}
EOF
        chown -R "$owner" "$cfgdir" 2>/dev/null || true
    done
    ok "crush installed (use: crush)"
}

# ─────────────────────────────────────────────────────────────────────────────
# gptme — Python agent with the broadest tool set among local-AI CLIs:
# shell, python eval, file save/patch, browser, vim, IPython, etc. Best
# Claude-Code-style autonomous behaviour, BUT needs a model that can do
# tool calls (Qwen2.5-Coder-7B or bigger; 3B hallucinates loops).
# ─────────────────────────────────────────────────────────────────────────────
install_gptme() {
    if command -v gptme >/dev/null 2>&1; then
        ok "gptme already installed"
        return
    fi
    ensure_uv
    rm -rf "$PIPX_HOME/venvs/gptme" 2>/dev/null
    log "Installing gptme via uv with Python 3.12 (~80 MB — many deps)"
    uv tool install --python 3.12 gptme

    # gptme reads model + endpoint from env vars at runtime, which our
    # /etc/profile.d/podroid-ai.sh already exports (OPENAI_BASE_URL,
    # OPENAI_API_KEY). Set GPTME_MODEL too so the CLI uses the right
    # routing key.
    grep -q "^export GPTME_MODEL=" "$ENV_FILE" || {
        cat >> "$ENV_FILE" <<EOF

# gptme uses litellm under the hood — "openai/<model>" routes to the
# OPENAI_BASE_URL endpoint, which we already point at the local server.
export GPTME_MODEL="openai/podroid"
EOF
    }
    ok "gptme installed (use: gptme \"prompt here\")"
}

# ─────────────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────────────
TOOLS=("$@")
case "${TOOLS[0]:-}" in
    --help|-h) usage; exit 0 ;;
esac
[ "${#TOOLS[@]}" -eq 0 ] && TOOLS=(all)

require_root "$@"
check_engine          # warning-only; doesn't abort
ensure_apt_deps
write_env_file
write_aider_conf

for tool in "${TOOLS[@]}"; do
    case "$tool" in
        all)     install_aider; install_sgpt; install_crush; install_gptme ;;
        aider)   install_aider ;;
        sgpt)    install_sgpt ;;
        crush)   install_crush ;;
        gptme)   install_gptme ;;
        --help|-h) usage; exit 0 ;;
        *)       fail "Unknown tool: $tool"; usage; exit 1 ;;
    esac
done

cat <<'EOF'

═══════════════════════════════════════════════════════════
  ✓ Local AI CLI tools ready.

  Open a new shell (env vars are auto-sourced) OR run:
    source /etc/profile.d/podroid-ai.sh

  Recommended model for agentic tools (Claude-Code-style use):
    Podroid app → Settings → AI Engine → Model →
      Qwen2.5-Coder 7B (~4.4 GB, follows tool-calls reliably)
    The default 3B is fine for sgpt one-shots but hallucinates
    tool loops in crush / gptme / aider.

  Then try:
    aider                          # AI pair programming, opens repo
    crush                          # Claude-Code-like TUI agent
    gptme "scan the local subnet"  # full autonomous agent
    sgpt "list /var/log tail-50"   # one-shot prompt
    sgpt --role podroid-shell --repl pentest    # pentest REPL
    podroid-ai "..."               # tiny curl wrapper

  Re-run this script anytime to upgrade tools or fix env config —
  it's idempotent.
═══════════════════════════════════════════════════════════
EOF
