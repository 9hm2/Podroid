#!/bin/bash
# Podroid - Rootless Podman for Android
# Copyright (C) 2024-2026 Podroid contributors
#
# Forward a prompt to the Android-side llama-server over SLIRP loopback.
# Streams the response token-by-token to stdout. Usage:
#   podroid-ai "explain the nmap output below: $(cat scan.txt)"
#   echo "what does this mean?" | podroid-ai
#   podroid-ai --system "You are a pentest assistant." "scan 10.0.0.0/24"
#
# Env:
#   PODROID_AI_HOST   override (default: http://10.0.2.2:8089)
#   PODROID_AI_TEMP   sampling temperature (default: 0.4)
#   PODROID_AI_MAX    max tokens (default: 512)

set -euo pipefail

ENDPOINT="${PODROID_AI_HOST:-http://10.0.2.2:8089}/v1/chat/completions"
TEMP="${PODROID_AI_TEMP:-0.4}"
MAX="${PODROID_AI_MAX:-512}"
SYSTEM=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --system) SYSTEM="$2"; shift 2 ;;
        --temp)   TEMP="$2";   shift 2 ;;
        --max)    MAX="$2";    shift 2 ;;
        --help|-h)
            sed -n '4,18p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *) break ;;
    esac
done

PROMPT="${*:-}"
if [[ -z "$PROMPT" ]]; then
    # Read from stdin when no args.
    PROMPT=$(cat)
fi
if [[ -z "$PROMPT" ]]; then
    echo "podroid-ai: empty prompt" >&2
    exit 1
fi

# jq builds the JSON safely (handles newlines, quotes, escapes inside the prompt).
BODY=$(
    if [[ -n "$SYSTEM" ]]; then
        jq -n --arg p "$PROMPT" --arg s "$SYSTEM" --argjson t "$TEMP" --argjson m "$MAX" '{
            model: "podroid", stream: true, temperature: $t, max_tokens: $m,
            messages: [{role:"system", content:$s}, {role:"user", content:$p}]
        }'
    else
        jq -n --arg p "$PROMPT" --argjson t "$TEMP" --argjson m "$MAX" '{
            model: "podroid", stream: true, temperature: $t, max_tokens: $m,
            messages: [{role:"user", content:$p}]
        }'
    fi
)

# -N disables curl's output buffering so tokens stream in real-time.
# Each SSE frame is "data: {...}"; we strip the prefix and pull the
# delta.content field. Stop on the [DONE] sentinel.
curl -sS -N "$ENDPOINT" \
    -H 'Content-Type: application/json' \
    --data-binary "$BODY" \
| while IFS= read -r line; do
    [[ "$line" == data:* ]] || continue
    payload="${line#data:}"
    payload="${payload# }"
    [[ "$payload" == "[DONE]" ]] && break
    # Tolerate transient non-JSON keepalives.
    delta=$(echo "$payload" | jq -r '.choices[0].delta.content // empty' 2>/dev/null || true)
    [[ -n "$delta" ]] && printf '%s' "$delta"
done
printf '\n'
