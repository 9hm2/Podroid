#!/bin/sh
# Reads RESIZE messages from /dev/hvc1 (ctrl.sock) and applies them via stty.
#
# Protocol (libpodroid-bridge writes one line per stable winsize):
#   RESIZE rows cols          -> apply to /dev/hvc0          (legacy / single-tab)
#   RESIZE <name> rows cols   -> apply to /dev/<name>        (in-app multi-tab)
#
# Also stamps /run/term_size_<name> (and /run/term_size for hvc0) so
# podroid-login can restore the winsize after each getty respawn — virtio-
# console resets winsize to 0x0 every time the line is reopened.
#
# No `set -e`: this is a long-lived `while read` daemon. A transient stty
# failure (e.g. /dev/hvcX momentarily unavailable during a getty respawn)
# or a tmpfs write hiccup must not terminate the daemon for the rest of
# the VM's life.

# Wait for the virtio-console node to appear (timing varies)
for _i in $(seq 1 30); do
    [ -c /dev/hvc1 ] && break
    sleep 1
done
[ -c /dev/hvc1 ] || exit 0

apply() {
    _tty=$1; _r=$2; _c=$3
    # Reject empty / non-numeric / zero rows or cols before persisting:
    # a malformed line must not stamp junk into /run/term_size* (which
    # podroid-login reads back) or stty a 0x0 winsize onto the tty.
    case "$_r" in ''|*[!0-9]*|0) return;; esac
    case "$_c" in ''|*[!0-9]*|0) return;; esac
    [ -c "/dev/$_tty" ] || return
    stty rows "$_r" cols "$_c" < "/dev/$_tty" 2>/dev/null
    printf '%s %s\n' "$_r" "$_c" > "/run/term_size_$_tty" 2>/dev/null
    # Keep /run/term_size pointing at hvc0 for backward compat with the
    # podroid-login wrapper's primary-tab restore path.
    [ "$_tty" = "hvc0" ] && printf '%s %s\n' "$_r" "$_c" > /run/term_size 2>/dev/null
}

while IFS= read -r _line; do
    case "$_line" in
        RESIZE\ *)
            set -- $_line
            # set -- splits on whitespace; $# now reflects field count.
            #   "RESIZE rows cols"        -> $# = 3 -> apply to hvc0
            #   "RESIZE <name> rows cols" -> $# = 4 -> apply to /dev/<name>
            case "$#" in
                3) apply "hvc0" "$2" "$3" ;;
                4) apply "$2" "$3" "$4" ;;
            esac
            ;;
    esac
done </dev/hvc1
